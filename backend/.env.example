# Backend Environment Variables

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:5173

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-random-64-char-string
JWT_REFRESH_SECRET=replace-with-random-64-char-string

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/oauth/google/callback

# ─── Email (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ─── Room Settings ──────────────────────────────────────────────────────────
MAX_PARTICIPANTS=8
ROOM_EXPIRY_HOURS=24
OTP_EXPIRY_MINUTES=10

# ─── Deepgram (Live Captions) ───────────────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key
CAPTION_TRANSCRIBE_PROVIDER=deepgram
DEEPGRAM_LIVE_MODEL=nova-3
DEEPGRAM_LIVE_LANGUAGE=en
DEEPGRAM_STREAM_URL=https://playerservices.streamtheworld.com/api/livestream-redirect/CSPANRADIOAAC.aac

# ─── Upstash Redis ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
REDIS_PASSWORD=replace-with-redis-password

# ─── WebRTC ICE/TURN ────────────────────────────────────────────────────────
ICE_CANDIDATE_POOL_SIZE=10
ICE_BUNDLE_POLICY=balanced
ICE_RTCP_MUX_POLICY=require
TRUST_PROXY=1

# ─── WebSocket ──────────────────────────────────────────────────────────────
WS_MAX_MESSAGE_BYTES=524288
WS_BACKPRESSURE_MAX_QUEUE=100
WS_BACKPRESSURE_MAX_AGE=5000
WS_BACKPRESSURE_DROP=false
