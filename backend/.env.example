# Scaling Configuration
# Number of Redis connections in the pool (default: 10)
REDIS_POOL_SIZE=10

# Maximum WebSocket message size in bytes (default: 524288)
WS_MAX_MESSAGE_BYTES=524288

# Trust proxy level (for load balancers)
# 0 = disabled, 1 = single proxy, 2 = two proxies
TRUST_PROXY=1

# Backpressure Configuration
WS_BACKPRESSURE_MAX_QUEUE=100
WS_BACKPRESSURE_MAX_AGE=5000
WS_BACKPRESSURE_DROP=false

# ICE/TURN Configuration
# Comma-separated STUN servers
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# Comma-separated TURN servers (turn: or turns:)
TURN_SERVERS=turn:your-turn-server.com:3478
TURN_SECRET=your-secret-key
TURN_TTL_SEC=86400

# RTCPeerConnection config
ICE_CANDIDATE_POOL_SIZE=10
ICE_BUNDLE_POLICY=balanced
ICE_RTCP_MUX_POLICY=require
TRUST_PROXY=1