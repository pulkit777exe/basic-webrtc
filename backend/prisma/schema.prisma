generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String            @id @default(uuid())
  username     String            @unique
  password     String
  name         String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  messages     Message[]
  analytics    Analytics[]
  createdRooms Room[]            @relation("RoomCreator")
  participants RoomParticipant[]
  recordings   Recording[]
}

model Room {
  id               String            @id @default(cuid())
  name             String            @unique
  creator          String
  creatorUser      User              @relation("RoomCreator", fields: [creator], references: [id])
  participants     String[]
  maxPeers         Int               @default(50)
  hostId           String?
  isLocked         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  messages         Message[]
  analytics        Analytics[]
  roomParticipants RoomParticipant[]
  recordings       Recording[]
  
  @@index([name])
}

model Message {
  id        String   @id @default(uuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId])
  @@index([createdAt])
}

model Analytics {
  id          String   @id @default(uuid())
  roomId      String?
  room        Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType   String // 'page_view', 'room_join', 'room_leave', 'message_sent', etc.
  browserInfo Json
  sessionId   String
  timestamp   DateTime @default(now())
  metadata    Json? // Additional event-specific data

  @@index([roomId])
  @@index([userId])
  @@index([eventType])
  @@index([timestamp])
}

model RoomParticipant {
  id           String   @id @default(uuid())
  roomId       String
  room         Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  socketId     String   @unique
  peerRole     String   @default("participant") // "host", "moderator", "participant"
  isAudioMuted Boolean  @default(false)
  isVideoMuted Boolean  @default(false)
  joinedAt     DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@index([socketId])
}

model Recording {
  id        String   @id @default(uuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  filePath  String
  startedAt DateTime
  endedAt   DateTime
  createdAt DateTime @default(now())

  @@index([roomId])
  @@index([userId])
}